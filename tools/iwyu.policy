# IWYU policy for NightDriverStrip.
#
# Keep rules here are loaded automatically by tools/audit_iwyu.py, so you do
# not need to pass them on every invocation.
#
# Format:
#   keep <glob>
#   mapping <path-to-iwyu-mapping-file>

keep globals.h
keep WString.h
keep esp_arduino_version.h
keep esp_idf_version.h
mapping tools/nightdriver.imp
